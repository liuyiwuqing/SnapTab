{
  "name": "snaptab",
  "version": "0.1.0",
  "private": true,
  "description": "SnapTab - Capture, edit, frame, and share screenshots in Chrome.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
